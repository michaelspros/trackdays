# Single-feed setup (legacy, still supported)
ICS_URL=https://example.com/published/your-calendar-token

# Multi-feed setup
# Add as many feeds as you want by incrementing the number.
# Each feed needs a _LABEL (shown in the UI selector) and a _URL (https only).
# The label is what the user picks in the dropdown at the top-left of the app.
#
# ICS_FEED_1_LABEL=Track A
# ICS_FEED_1_URL=https://example.com/published/feed-a-token
#
# ICS_FEED_2_LABEL=Track B
# ICS_FEED_2_URL=https://example.com/published/feed-b-token
#
# ICS_FEED_3_LABEL=Track C
# ICS_FEED_3_URL=https://example.com/published/feed-c-token
